            "name": "List datasets and assets",
            "description": {
              "content": "Returns a JSON list of all datasets, views, charts, and assets published\non the AmeriCorps open data portal. Useful for discovery and for\nretrieving dataset identifiers (`id`) needed to call `/resource/{id}`.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "views"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "<integer>",
                  "description": "Maximum number of assets to return."
                },
                {
                  "disabled": false,
                  "key": "page",
                  "value": "<integer>",
                  "description": "Page number for paginated catalog responses."
